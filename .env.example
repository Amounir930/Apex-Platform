# Apex Platform - Environment Template
# Generated automatically from Zod schemas
# Protocol Alpha 1: DO NOT USE DEFAULTS FOR SECRETS

# --- COMMON VARIABLES ---
# Current application environment (dev/prod/test)
NODE_ENV=development

# Minimum logging level for the application
LOG_LEVEL=info

# The port on which the server listens
PORT=3000

# The host interface to bind the server to
HOST=0.0.0.0

# --- API SPECIFIC ---
# Secret key used for signing JWT tokens. Required for authentication.
JWT_SECRET=changeme_in_production

# PostgreSQL connection string. Sole source of truth for DB access.
DATABASE_URL=postgres://user:pass@localhost:5432/db

# Redis connection string for caching and task queue.
REDIS_URL=postgres://user:pass@localhost:5432/db

# --- WORKER SPECIFIC ---
# PostgreSQL connection string for the worker background tasks.
DATABASE_URL=postgres://user:pass@localhost:5432/db

# Redis connection string for the worker task queue.
REDIS_URL=postgres://user:pass@localhost:5432/db

# Prefix for BullMQ queue names to avoid collisions.
QUEUE_PREFIX=apex-worker

# --- STOREFRONT SPECIFIC ---
# The public-facing URL of the API gateway for the storefront frontend.
API_URL=postgres://user:pass@localhost:5432/db

# Enable global maintenance page for the storefront.
MAINTENANCE_MODE=false
